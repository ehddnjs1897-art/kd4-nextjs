# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Kakao OAuth ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_JS_KEY=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase

# ─── Cloudflare R2 (배우 출연영상 private 호스팅) ─────────────────────────────
# 가입: https://dash.cloudflare.com/sign-up
# R2 → Create bucket "kd4-actor-videos" → Manage API Tokens
R2_ACCOUNT_ID=                # Cloudflare 대시보드 우측 사이드바
R2_ACCESS_KEY_ID=             # R2 API Token 발급 시 노출
R2_SECRET_ACCESS_KEY=         # R2 API Token 발급 시 노출 (한 번만!)
R2_BUCKET_NAME=kd4-actor-videos

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kd4.club

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_KEY=                   # 서버 전용 — NEXT_PUBLIC_ 사용 금지 (키 노출 방지)

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Google Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ─── Meta Pixel ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Meta Marketing API (광고 인사이트 조회) ────────────────────────────────
# Graph API Explorer (developers.facebook.com/tools/explorer) → ads_read 권한
# scripts/fetch-meta-ads-insights.ts 실행 시 필요
META_ADS_ACCESS_TOKEN=

# ─── SMS (Solapi) ─────────────────────────────────────────────────────────────
# https://console.solapi.com → API Key 발급
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_FROM_NUMBER=           # 발신번호 (사전 등록 필요, 예: 01012345678)
ADMIN_PHONE_NUMBER=           # 대표 연락처 (신규 상담 알림 수신)

# ─── Make.com 웹훅 ────────────────────────────────────────────────────────────
MAKE_WEBHOOK_URL=             # Make.com → 구글시트 연동 웹훅 URL
