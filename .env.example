# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Kakao OAuth ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_JS_KEY=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kd4.club

# ─── Gemini AI ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GEMINI_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Google Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ─── Meta Pixel ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=

# ─── SMS (Solapi) ─────────────────────────────────────────────────────────────
# https://console.solapi.com → API Key 발급
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_FROM_NUMBER=           # 발신번호 (사전 등록 필요, 예: 01012345678)
ADMIN_PHONE_NUMBER=           # 대표 연락처 (신규 상담 알림 수신)

# ─── Make.com 웹훅 ────────────────────────────────────────────────────────────
MAKE_WEBHOOK_URL=             # Make.com → 구글시트 연동 웹훅 URL
